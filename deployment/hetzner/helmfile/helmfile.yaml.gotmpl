repositories:
  - name: prometheus-community
    url: https://prometheus-community.github.io/helm-charts

apiVersions:
  - monitoring.coreos.com/v1

releases:
  - name: prometheus
    namespace: monitoring
    chart: prometheus-community/kube-prometheus-stack

  - name: ocelot-social
    namespace: ocelot-social
    chart: ./ocelot-social
    values:
    - ./values/ocelot.yaml
    secrets:
      - ./secrets/ocelot.yaml
